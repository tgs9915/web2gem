# Host port exposed by Docker Compose.
PORT=52389

# Docker image used by Docker Compose. Override this to pin a release tag.
WEB2GEM_IMAGE=ghcr.io/guardinary/web2gem:latest

# Optional auth. Empty API_KEYS disables authentication.
API_KEYS=

# Optional Gemini Web cookie. Needed only for real Pro routing and
# large-context text attachments.
# Example: __Secure-1PSID=...;__Secure-1PSIDTS=...;SAPISID=...
# Optional SAPISID; leave blank to automatically extract from the cookie above.
GEMINI_COOKIE=
SAPISID=

# Docker self-hosting should keep socket transport disabled unless the runtime
# provides cloudflare:sockets.
UPSTREAM_SOCKET=false

# Optional runtime overrides.
GEMINI_BL=
GEMINI_ORIGIN=
DEFAULT_MODEL=
RETRY_ATTEMPTS=
RETRY_DELAY_SEC=
REQUEST_TIMEOUT_SEC=
LOG_REQUESTS=
CURRENT_INPUT_FILE_ENABLED=
CURRENT_INPUT_FILE_MIN_BYTES=
CURRENT_INPUT_FILE_NAME=
CURRENT_TOOLS_FILE_NAME=
GENERIC_FILE_UPLOAD_MAX_BYTES=
